<div class="card shadow-sm">
  <div class="card-body">
    <h1><%= @pet.name %></h1>
    <p><strong>Species:</strong> <%= @pet.species %></p>
    <p><strong>Breed:</strong> <%= @pet.breed %></p>
    <p><strong>Date of Birth:</strong> <%= @pet.date_of_birth %></p>
    <p><strong>Weight:</strong> <%= @pet.weight %> kg</p>
    <p><strong>Owner:</strong> <%= link_to @pet.owner.first_name, owner_path(@pet.owner) %></p>

    <h3 class="mt-4">Appointments:</h3>
    <div class="list-group">
      <% @pet.appointments.each do |app| %>
        <%= link_to appointment_path(app), class: "list-group-item list-group-item-action" do %>
          <%= app.date.strftime("%d/%m/%Y") %> - <%= app.reason %>
        <% end %>
      <% end %>
    </div>

    <div class="mt-3">
      <%= link_to "Edit Pet",
          edit_pet_path(@pet),
          class: "btn btn-sm btn-warning text-white" %>

      <%= button_to "Delete Pet",
          pet_path(@pet),
          method: :delete,
          data: { turbo_confirm: "Are you sure?" },
          class: "btn btn-sm btn-danger",
          form: { class: "d-inline" } %>
    </div>

    <div>
      <%= link_to "Back to Pets", pets_path, class: "btn btn-secondary mt-3" %>
    </div>

  </div>
</div>