<div class="card shadow-sm">
  <div class="card-body">
    <h1>Appointment Details</h1>

    <p><strong>Date:</strong> <%= @appointment.date.strftime("%B %d, %Y at %H:%M") %></p>
    <p><strong>Reason:</strong> <%= @appointment.reason %></p>
    <p>
      <strong>Status:</strong>
      <span class="badge bg-info text-dark">
        <%= @appointment.status.humanize %>
      </span>
    </p>

    <hr>

    <p>
      <strong>Patient (Pet):</strong>
      <%= link_to @appointment.pet.name, pet_path(@appointment.pet) %>
    </p>

    <p>
      <strong>Veterinarian:</strong>
      <%= link_to @appointment.vet.first_name, vet_path(@appointment.vet) %>
    </p>

    <div class="mt-3">
      <%= link_to "Edit Appointment",
          edit_appointment_path(@appointment),
          class: "btn btn-sm btn-warning text-white" %>

      <%= button_to "Delete Appointment",
          appointment_path(@appointment),
          method: :delete,
          data: { turbo_confirm: "Are you sure?" },
          class: "btn btn-sm btn-danger",
          form: { class: "d-inline" } %>
    </div>

    <%= link_to "Back to Appointments",
        appointments_path,
        class: "btn btn-secondary mt-3" %>
  </div>
</div>

<div class="card shadow-sm mt-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h3 class="mb-0">Treatments</h3>

      <%= link_to "New Treatment",
          new_appointment_treatment_path(@appointment),
          class: "btn btn-primary btn-sm" %>
    </div>

    <% if @appointment.treatments.any? %>
      <table class="table table-hover">
        <thead class="table-light">
          <tr>
            <th>Name</th>
            <th>Administered at</th>
            <th class="text-center">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @appointment.treatments.each do |treatment| %>
            <tr>
              <td class="align-middle"><%= treatment.name %></td>
              <td class="align-middle">
                <%= treatment.administered_at.strftime("%B %d, %Y at %H:%M") %>
              </td>
              <td>
                <div class="d-flex gap-2 justify-content-center">
                  <%= link_to "Edit",
                      edit_appointment_treatment_path(@appointment, treatment),
                      class: "btn btn-sm btn-warning text-white" %>

                  <%= button_to "Delete",
                      appointment_treatment_path(@appointment, treatment),
                      method: :delete,
                      data: { turbo_confirm: "Are you sure?" },
                      class: "btn btn-sm btn-danger",
                      form: { class: "d-inline" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-muted">No treatments yet.</p>
    <% end %>
  </div>
</div>