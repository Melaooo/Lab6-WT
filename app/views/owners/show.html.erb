<div class="card shadow-sm">
  <div class="card-body">
    <h1 class="card-title"><%= @owner.first_name %> <%= @owner.last_name %></h1>
    <p><strong>Email:</strong> <%= @owner.email %></p>
    <p><strong>Phone:</strong> <%= @owner.phone %></p>
    <p><strong>Address:</strong> <%= @owner.address %></p>

    <h3 class="mt-4">Pets:</h3>
    <ul class="list-group">
      <% @owner.pets.each do |pet| %>
        <li class="list-group-item d-flex justify-content-between align-items-center">
          <%= pet.name %> (<%= pet.species %>)
          <%= link_to "View Pet", pet_path(pet), class: "btn btn-sm btn-outline-primary" %>
        </li>
      <% end %>
    </ul>

    <div class="mt-3">
      <%= link_to "Edit Owner",
          edit_owner_path(@owner),
          class: "btn btn-sm btn-warning text-white" %>

      <%= button_to "Delete Owner",
          owner_path(@owner),
          method: :delete,
          data: { turbo_confirm: "Are you sure?" },
          class: "btn btn-sm btn-danger",
          form: { class: "d-inline" } %>
    </div>
    
    <%= link_to "Back to Owners List", owners_path, class: "btn btn-secondary mt-3" %>
  </div>
</div>