<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Owners List</h1>
</div>

<button class="btn btn-primary mb-3" onclick="window.location.href='<%= new_owner_path %>'">Add New Owner</button>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-dark">
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th class="text-center">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @owners.each do |owner| %>
          <tr>
            <td class="align-middle">
              <%= "#{owner.first_name} #{owner.last_name}" %>
            </td>
            <td class="align-middle"><%= owner.email %></td>
            <td class="align-middle"><%= owner.phone %></td>
            <th>
              <div class="d-flex gap-2 allign-items-center justify-content-center">
                <%= link_to "View", owner_path(owner), class: "btn btn-sm btn-info text-white" %>

                <%= link_to "Edit", edit_owner_path(owner), class: "btn btn-sm btn-warning text-white" %>

                <%= button_to "Delete",
                    owner_path(owner),
                    method: :delete,
                    data: { turbo_confirm: "Are you sure?" },
                    class: "btn btn-sm btn-danger",
                    form: { class: "d-inline" } %>
              </div>
            </th>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>